      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Handbook-Enterprises/ve-track.git"
  },
  "homepage": "https://track.viewengine.ai",
  "private": false,
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@clerk/backend": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@clerk/backend": {
      "optional": true
    }
  },
  "devDependencies": {
    "@clerk/backend": "^2.30.1",
    "@cloudflare/workers-types": "^4.20251002.0",
    "typescript": "^5.9.2"
  }
